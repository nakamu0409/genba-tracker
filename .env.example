# 現場記録の共有マスタ(会場・アイドル・グループ)に書き込める管理者用の合言葉
# 未設定の場合は誰も管理者ログインできず、マスタは読み取り専用になる
GENBA_ADMIN_KEY=

# アイドルの写真保存用 Cloudflare R2 (S3互換ストレージ)
# 未設定の場合は写真アップロード機能がエラーになるが、他の機能には影響しない
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
# R2バケットの公開URLのベース（公開バケットURL or カスタムドメイン。末尾スラッシュなし）
R2_PUBLIC_URL_BASE=
